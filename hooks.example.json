{
  "version": 1,
  "hooks": {
    "stop": [
      { "command": "/ABS/PATH/TO/~/.cursor/cursor-pulse/notify.sh", "timeout": 5 }
    ],
    "sessionStart": [
      { "command": "/ABS/PATH/TO/~/.cursor/cursor-pulse/notify.sh", "timeout": 5 }
    ],
    "sessionEnd": [
      { "command": "/ABS/PATH/TO/~/.cursor/cursor-pulse/notify.sh", "timeout": 5 }
    ],
    "afterShellExecution": [
      { "command": "/ABS/PATH/TO/~/.cursor/cursor-pulse/notify.sh", "timeout": 5 }
    ],
    "preCompact": [
      { "command": "/ABS/PATH/TO/~/.cursor/cursor-pulse/notify.sh", "timeout": 5 }
    ]
  }
}
