#!/bin/sh
#
# cursor-pulse — manage your cursor-pulse install (status line + notifications).

set -u

CURSOR_PULSE_VERSION="0.2.0"
CURSOR_DIR=${CURSOR_CONFIG_DIR:-"$HOME/.cursor"}
INSTALL_DIR="$CURSOR_DIR/cursor-pulse"
RAW_URL=${PULSE_RAW_URL:-"https://raw.githubusercontent.com/martinoyovo/cursor-pulse/main"}

usage() {
  cat <<EOF
cursor-pulse $CURSOR_PULSE_VERSION — status line + notifications for the Cursor CLI.

Usage: cursor-pulse <command>

Commands:
  status              Render the on-demand status line from captured session state.
  test [stop|shell]   Fire a test notification (default: stop).
  doctor              Check install health (hooks, deps, cursor-agent).
  update              Re-install the latest version from GitHub.
  uninstall           Remove cursor-pulse entirely.
  version             Print the installed version.
  help                Show this help.
EOF
}

fetch() {
  if command -v curl >/dev/null 2>&1; then curl -fsSL "$1"
  elif command -v wget >/dev/null 2>&1; then wget -qO- "$1"
  else printf 'Need curl or wget.\n' >&2; return 1
  fi
}

cmd=${1:-help}
case "$cmd" in
  status)
    if [ -x "$INSTALL_DIR/statusline.sh" ]; then
      "$INSTALL_DIR/statusline.sh" </dev/null
    elif [ -x "$(dirname -- "$0")/statusline.sh" ]; then
      "$(dirname -- "$0")/statusline.sh" </dev/null
    else
      printf 'statusline.sh not found — is cursor-pulse installed?\n' >&2
      exit 1
    fi
    ;;
  test|--test)
    what=${2:-stop}
    notify_sh="$INSTALL_DIR/notify.sh"
    [ -x "$notify_sh" ] || notify_sh="$(dirname -- "$0")/hooks/notify.sh"
    [ -x "$notify_sh" ] || notify_sh="$(dirname -- "$0")/notify.sh"
    case "$what" in
      shell)
        ev='{"hook_event_name":"afterShellExecution","command":"echo hello","workspace_roots":["'"$PWD"'"],"conversation_id":"test","model":"test","cwd":"'"$PWD"'"}'
        CURSOR_PULSE_NOTIFY_ON_SHELL=1 export CURSOR_PULSE_NOTIFY_ON_SHELL
        ;;
      stop)
        ev='{"hook_event_name":"stop","status":"completed","workspace_roots":["'"$PWD"'"],"conversation_id":"test","model":"test","cwd":"'"$PWD"'"}'
        ;;
      *)
        printf 'Unknown test type: %s (use stop|shell)\n' "$what" >&2
        exit 2
        ;;
    esac
    if [ -x "$notify_sh" ]; then
      printf '%s' "$ev" | "$notify_sh"
      printf 'Fired a "%s" test notification.\n' "$what"
    else
      printf 'notify.sh not found — is cursor-pulse installed?\n' >&2
      exit 1
    fi
    ;;
  doctor)
    printf 'cursor-pulse doctor\n\n'
    printf 'Install dir: %s\n' "$INSTALL_DIR"
    if [ -d "$INSTALL_DIR" ]; then printf '  [ok] exists\n'; else printf '  [!!] missing\n'; fi
    if [ -x "$INSTALL_DIR/notify.sh" ]; then printf '  [ok] notify.sh\n'; else printf '  [!!] notify.sh missing\n'; fi
    if [ -x "$INSTALL_DIR/statusline.sh" ]; then printf '  [ok] statusline.sh\n'; else printf '  [!!] statusline.sh missing\n'; fi

    hooks_file="$CURSOR_DIR/hooks.json"
    printf '\nHooks file: %s\n' "$hooks_file"
    if [ -f "$hooks_file" ] && grep -q 'cursor-pulse' "$hooks_file" 2>/dev/null; then
      printf '  [ok] cursor-pulse entries found\n'
    elif [ -f "$hooks_file" ]; then
      printf '  [!!] no cursor-pulse entries (run install.sh)\n'
    else
      printf '  [!!] hooks.json missing\n'
    fi

    printf '\nDependencies:\n'
    for dep in jq git cursor-agent terminal-notifier notify-send osascript; do
      if command -v "$dep" >/dev/null 2>&1; then
        ver=$("$dep" --version 2>/dev/null | head -n 1 || printf 'found')
        printf '  [ok] %s (%s)\n' "$dep" "$ver"
      else
        printf '  [--] %s not found\n' "$dep"
      fi
    done
    ;;
  update|--update|-u)
    printf 'Updating cursor-pulse (current: %s) from %s ...\n' "$CURSOR_PULSE_VERSION" "$RAW_URL"
    fetch "$RAW_URL/install.sh" | sh
    ;;
  uninstall|--uninstall)
    shift 2>/dev/null || true
    if [ -x "$INSTALL_DIR/uninstall.sh" ]; then
      "$INSTALL_DIR/uninstall.sh" "$@"
    else
      fetch "$RAW_URL/uninstall.sh" | sh -s -- "$@"
    fi
    ;;
  version|--version|-v)
    printf 'cursor-pulse %s\n' "$CURSOR_PULSE_VERSION"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    printf 'Unknown command: %s\n\n' "$cmd" >&2
    usage >&2
    exit 2
    ;;
esac
